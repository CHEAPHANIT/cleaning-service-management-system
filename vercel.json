{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["sin1"],
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "build/web",
  "functions": {
    "api/index.py": {
      "includeFiles": "server/openapi.json",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api?__path=:path*" }
  ]
}
