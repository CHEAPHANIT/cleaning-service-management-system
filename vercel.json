{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["sin1"],
  "buildCommand": "git clone --depth 1 --branch 3.44.0 https://github.com/flutter/flutter.git /tmp/flutter && /tmp/flutter/bin/flutter build web --release --dart-define=CLEAN_NOW_API_URL=https://$VERCEL_PROJECT_PRODUCTION_URL/api --dart-define=CLEAN_NOW_PUBLIC_URL=https://$VERCEL_PROJECT_PRODUCTION_URL",
  "outputDirectory": "build/web",
  "functions": {
    "api/index.py": {
      "includeFiles": "server/openapi.json",
      "maxDuration": 60
    }
  }
}
